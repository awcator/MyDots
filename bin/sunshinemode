#!/bin/bash
# sunshinemode — Switch to virtual display config and launch Sunshine for streaming
# On exit (Ctrl+C / kill), reverts to normal config and restarts X
# On startup, checks if a previous crash left virtual config active and recovers

SUNSHINE_CONF="$HOME/.config/sunshine/sunshine.conf"
DETECT_LOG="/tmp/sunshine-detect-$$.log"
XCONF_DIR="/etc/X11/xorg.conf.d"
REAL_CONF="$XCONF_DIR/10-nvidia-primary.conf"
VIRTUAL_CONF="$XCONF_DIR/10-nvidia-virtual.conf"
SUDO_PASS="G0getazb00bfreeza"

PHONE_MODE="2340x1080_60.00"

do_sudo() {
    echo "$SUDO_PASS" | sudo -S "$@" 2>/dev/null
}

swap_to_virtual() {
    do_sudo bash -c "
        mv '$REAL_CONF' '${REAL_CONF}.disabled' 2>/dev/null
        mv '${VIRTUAL_CONF}.disabled' '$VIRTUAL_CONF' 2>/dev/null
    "
}

swap_to_real() {
    do_sudo bash -c "
        mv '$VIRTUAL_CONF' '${VIRTUAL_CONF}.disabled' 2>/dev/null
        mv '${REAL_CONF}.disabled' '$REAL_CONF' 2>/dev/null
    "
}

get_xauth() {
    # Get XAUTHORITY from the running Xorg process
    local auth=$(pgrep -a Xorg | grep ":0" | grep -oP '(?<=-auth )\S+')
    echo "$auth"
}

wait_for_x() {
    echo "Waiting for X server..."
    for i in $(seq 1 30); do
        local auth=$(get_xauth)
        if [ -n "$auth" ] && DISPLAY=:0 XAUTHORITY="$auth" xrandr &>/dev/null; then
            export DISPLAY=:0
            export XAUTHORITY="$auth"
            echo "X server ready (XAUTHORITY=$auth)"
            return 0
        fi
        sleep 1
    done
    echo "ERROR: X server did not start in time"
    return 1
}

# --- Crash recovery ---
if [ -f "$VIRTUAL_CONF" ] && [ ! -f "$REAL_CONF" ]; then
    echo "WARNING: Virtual config was left active (previous crash?). Recovering..."
    swap_to_real
    echo "Recovered. Real config restored."
    echo "Run sunshinemode again to start streaming."
    exit 0
fi

cleanup() {
    echo ""
    echo "Reverting to normal desktop..."
    killall sunshine 2>/dev/null
    sleep 1

    swap_to_real
    sed -i '/^output_name/d' "$SUNSHINE_CONF" 2>/dev/null
    rm -f "$DETECT_LOG"

    echo "Restarting X with normal config..."
    do_sudo killall Xorg
    sleep 2
    startx -- :0 vt1 &
    echo "Done. Normal desktop restored."
    exit 0
}

trap cleanup EXIT INT TERM HUP

# --- Switch to virtual config ---
echo "Switching to virtual display config..."
swap_to_virtual

echo "Restarting X with virtual display..."
do_sudo killall Xorg
sleep 3
startx -- :0 vt1 &

wait_for_x || exit 1

# Wait for xinitrc/PRIME outputs to settle
sleep 5

# --- Find virtual output ---
# Pick the virtual output that supports 1920x1080 (better than 1024x768-only ones)
# Virtual outputs: connected, not eDP, no real physical dimensions
VIRTUAL_OUTPUT=""
for out in $(xrandr | grep " connected" | grep -v eDP | grep -v "[1-9][0-9][0-9]mm" | awk '{print $1}'); do
    if xrandr | grep -A5 "^${out} " | grep -q "1920x1080"; then
        VIRTUAL_OUTPUT="$out"
        break
    fi
done
# Fallback: any virtual output
if [ -z "$VIRTUAL_OUTPUT" ]; then
    VIRTUAL_OUTPUT=$(xrandr | grep " connected" | grep -v eDP | grep -v "[1-9][0-9][0-9]mm" | awk '{print $1}' | head -1)
fi

if [ -z "$VIRTUAL_OUTPUT" ]; then
    echo "ERROR: No virtual display found."
    xrandr | grep "connected"
    exit 1
fi

echo "Virtual output: $VIRTUAL_OUTPUT"

# Turn off other virtual outputs to free CRTCs
for out in $(xrandr | grep " connected" | grep -v eDP | grep -v "[1-9][0-9][0-9]mm" | awk '{print $1}'); do
    if [ "$out" != "$VIRTUAL_OUTPUT" ]; then
        xrandr --output "$out" --off 2>/dev/null
    fi
done

# Add S23 Ultra mode (2340x1080 @ 60Hz, ~164MHz fits TMDS 165MHz)
xrandr --newmode "$PHONE_MODE" 164.00 2340 2488 2736 3132 1080 1083 1093 1120 -hsync +vsync 2>/dev/null
xrandr --addmode "$VIRTUAL_OUTPUT" "$PHONE_MODE" 2>/dev/null

# Try modes: 1920x1080 best for S23 Ultra (scales perfectly), then phone mode, then auto
if xrandr --output "$VIRTUAL_OUTPUT" --mode 1920x1080 --left-of eDP-1 2>/dev/null; then
    echo "Set virtual display to 1920x1080 (fits S23 Ultra)"
elif xrandr --output "$VIRTUAL_OUTPUT" --mode "$PHONE_MODE" --left-of eDP-1 2>/dev/null; then
    echo "Set virtual display to S23 Ultra native ($PHONE_MODE)"
else
    xrandr --output "$VIRTUAL_OUTPUT" --auto --left-of eDP-1 2>/dev/null
    echo "Set virtual display to auto mode"
fi

echo "Display layout:"
xrandr --listmonitors

# --- Detect Sunshine display ID ---
echo ""
echo "Detecting Sunshine display ID..."
sed -i '/^output_name/d' "$SUNSHINE_CONF"

timeout 4 sunshine > "$DETECT_LOG" 2>&1 || true
sleep 1

DISPLAY_ID=$(grep -oP "Detected display: ${VIRTUAL_OUTPUT} \(id: \K[0-9]+" "$DETECT_LOG")
if [ -z "$DISPLAY_ID" ]; then
    DISPLAY_ID=$(grep -oP "Detected display: \S+ \(id: \K[0-9]+" "$DETECT_LOG" | tail -1)
fi
rm -f "$DETECT_LOG"

if [ -z "$DISPLAY_ID" ]; then
    echo "WARNING: Could not detect Sunshine display ID."
else
    echo "Found $VIRTUAL_OUTPUT as Sunshine display ID: $DISPLAY_ID"
    echo "output_name = $DISPLAY_ID" >> "$SUNSHINE_CONF"
fi

echo ""
echo "*** Connect via Moonlight to stream ***"
echo "*** Press Ctrl+C to stop and revert ***"
echo ""

# --- Launch Sunshine ---
sunshine &
SUNSHINE_PID=$!
wait $SUNSHINE_PID
