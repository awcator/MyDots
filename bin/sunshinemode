#!/bin/bash
# sunshinemode — Switch to virtual display config and launch Sunshine for streaming
# On exit (Ctrl+C / kill), reverts to normal config and restarts X

SUNSHINE_CONF="$HOME/.config/sunshine/sunshine.conf"
DETECT_LOG="/tmp/sunshine-detect-$$.log"
XCONF_DIR="/etc/X11/xorg.conf.d"
REAL_CONF="$XCONF_DIR/10-nvidia-primary.conf"
VIRTUAL_CONF="$XCONF_DIR/10-nvidia-virtual.conf"
SUDO_PASS="G0getazb00bfreeza"

cleanup() {
    echo ""
    echo "Reverting to normal desktop..."
    killall sunshine 2>/dev/null
    sleep 1

    # Swap configs back to real
    echo "$SUDO_PASS" | sudo -S bash -c "
        mv '$VIRTUAL_CONF' '${VIRTUAL_CONF}.disabled' 2>/dev/null
        mv '${REAL_CONF}.disabled' '$REAL_CONF' 2>/dev/null
    "

    # Remove output_name from sunshine.conf
    sed -i '/^output_name/d' "$SUNSHINE_CONF" 2>/dev/null
    rm -f "$DETECT_LOG"

    # Restart X with real config
    echo "Restarting X with normal config..."
    echo "$SUDO_PASS" | sudo -S killall Xorg 2>/dev/null
    sleep 2
    startx -- :0 vt1 &
    echo "Done. Normal desktop restored."
    exit 0
}

trap cleanup EXIT INT TERM HUP

# --- Switch to virtual config ---
echo "Switching to virtual display config..."
echo "$SUDO_PASS" | sudo -S bash -c "
    mv '$REAL_CONF' '${REAL_CONF}.disabled' 2>/dev/null
    mv '${VIRTUAL_CONF}.disabled' '$VIRTUAL_CONF' 2>/dev/null
"

# Restart X with virtual config
echo "Restarting X with virtual display..."
echo "$SUDO_PASS" | sudo -S killall Xorg 2>/dev/null
sleep 3
startx -- :0 vt1 &
sleep 7

# Find XAUTHORITY
export DISPLAY=:0
export XAUTHORITY=$(ls -t /tmp/serverauth.* 2>/dev/null | head -1)

# --- Find virtual output (0mm x 0mm) ---
VIRTUAL_OUTPUT=$(xrandr | grep " connected" | grep "0mm x 0mm" | awk '{print $1}' | head -1)

if [ -z "$VIRTUAL_OUTPUT" ]; then
    echo "ERROR: No virtual display found."
    xrandr | grep "connected"
    exit 1
fi

echo "Virtual output: $VIRTUAL_OUTPUT"

# Position virtual display
xrandr --output "$VIRTUAL_OUTPUT" --mode 1920x1080 --left-of eDP-1 2>/dev/null || \
    xrandr --output "$VIRTUAL_OUTPUT" --auto --left-of eDP-1 2>/dev/null

# Add S23 Ultra phone mode
PHONE_MODE="2344x1080_60.00"
xrandr --newmode "$PHONE_MODE" 211.25 2344 2496 2744 3144 1080 1083 1093 1120 -hsync +vsync 2>/dev/null
xrandr --addmode "$VIRTUAL_OUTPUT" "$PHONE_MODE" 2>/dev/null

echo "Display layout:"
xrandr --listmonitors

# --- Detect Sunshine display ID ---
echo ""
echo "Detecting Sunshine display ID..."
sed -i '/^output_name/d' "$SUNSHINE_CONF"

timeout 4 sunshine > "$DETECT_LOG" 2>&1 || true
sleep 1

DISPLAY_ID=$(grep -oP "Detected display: ${VIRTUAL_OUTPUT} \(id: \K[0-9]+" "$DETECT_LOG")
if [ -z "$DISPLAY_ID" ]; then
    DISPLAY_ID=$(grep -oP "Detected display: \S+ \(id: \K[0-9]+" "$DETECT_LOG" | tail -1)
fi
rm -f "$DETECT_LOG"

if [ -z "$DISPLAY_ID" ]; then
    echo "WARNING: Could not detect Sunshine display ID."
else
    echo "Found $VIRTUAL_OUTPUT as Sunshine display ID: $DISPLAY_ID"
    echo "output_name = $DISPLAY_ID" >> "$SUNSHINE_CONF"
fi

echo ""
echo "*** Connect via Moonlight to stream ***"
echo "*** Press Ctrl+C to stop and revert ***"
echo ""

# --- Launch Sunshine ---
sunshine &
SUNSHINE_PID=$!
wait $SUNSHINE_PID
